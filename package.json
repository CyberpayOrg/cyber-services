    "./tempo": {
      "types": "./dist/methods/tempo/index.d.ts",
      "src": "./src/methods/tempo/index.ts",
      "default": "./dist/methods/tempo/index.js"
    }
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
